rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isImageUpload() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    match /users/{userId}/kyc/{docType}/{fileName} {
      allow read: if true;
      allow write: if isImageUpload();
      allow delete: if true;
    }

    match /catalog/products/{productId}/{fileName} {
      allow read: if true;
      allow write: if isImageUpload();
      allow delete: if true;
    }

    match /catalog/drafts/{sessionId}/{fileName} {
      allow read: if true;
      allow write: if isImageUpload();
      allow delete: if true;
    }
  }
}
